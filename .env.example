# ==============================================
# TBN-IMS 環境変数テンプレート
# このファイルをコピーして .env を作成してください
#   cp .env.example .env
# ==============================================

# アプリ
APP_ENV=development
APP_URL=https://www.mszapps.com

# JWT
SECRET_KEY=please-change-me-to-a-32+-character-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS（カンマ区切り）
CORS_ORIGINS=https://www.mszapps.com,http://localhost:3000

# PostgreSQL
POSTGRES_HOST=tbn-ims-db
POSTGRES_PORT=5432
POSTGRES_DB=tbn_ims
POSTGRES_USER=tbn_ims_user
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Active Directory LDAP
LDAP_ENABLED=false
LDAP_SERVER=ldap://192.168.0.1
LDAP_BASE_DN=DC=example,DC=local
LDAP_BIND_DN=CN=service_account,DC=example,DC=local
LDAP_BIND_PASSWORD=service-account-password
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

# SMTPリレー
SMTP_ENABLED=false
SMTP_HOST=smtp.example.local
SMTP_PORT=587
SMTP_USER=ims-noreply@tbn.local
SMTP_PASSWORD=
SMTP_FROM=ims-noreply@tbn.local
SMTP_USE_TLS=true

# ConoHa オブジェクトストレージ（バックアップ用）
CONOHA_OS_ENDPOINT=
CONOHA_OS_USERNAME=
CONOHA_OS_PASSWORD=
CONOHA_OS_CONTAINER=tbn-ims-backup

# Frontend
NEXT_PUBLIC_API_URL=https://www.mszapps.com/api/v1
